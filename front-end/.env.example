# Supabase Configuration
# Get these values from your Supabase project settings

# Your Supabase project URL
# Format: https://xxxxx.supabase.co
# Example: https://eikzpnipvywmqdfkcdye.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anonymous Key (ANON_KEY)
# IMPORTANT: This is safe to expose in frontend code
# Never use SERVICE_ROLE_KEY in frontend
# Get this from: Project Settings → API → anon key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Enable Debug Mode (useful for development)
# Set to "true" to see detailed logs
VITE_DEBUG_MODE=false
